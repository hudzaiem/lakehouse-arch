# ================================================================
# Lakehouse ETL — Environment Variables
# ================================================================
# Copy this file to .env.lakehouse and fill in the values:
#   cp .env.lakehouse.example .env.lakehouse

# ----------------------------------------------------------------
# GCS — Google Cloud Storage
# ----------------------------------------------------------------
# Paste the FULL JSON content of your GCS service account key (single line)
# The SA should have Storage Object Admin permission on the bucket
GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# GCS bucket name (tanpa gs:// prefix)
GCS_BUCKET=your-lakehouse-bucket

# ----------------------------------------------------------------
# Kafka — Connection ke Kafka cluster
# ----------------------------------------------------------------
# Kafka LOKAL (compose terpisah, 1 VM) — internal listener, no auth:
KAFKA_BOOTSTRAP_SERVERS=kafka-1:29092,kafka-2:29092,kafka-3:29092
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT   (default, tidak perlu set)
#
# Kafka REMOTE — external listener + SASL, uncomment & isi:
# KAFKA_BOOTSTRAP_SERVERS=<PUBLIC_IP>:9092,<PUBLIC_IP>:9093,<PUBLIC_IP>:9094
# KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
# KAFKA_SASL_USERNAME=your-client-user
# KAFKA_SASL_PASSWORD=your-client-password
KAFKA_TOPIC=stock-stream

# ----------------------------------------------------------------
# Docker Network — OPTIONAL, hanya untuk Kafka lokal
# ----------------------------------------------------------------
# Set ini HANYA jika Kafka berjalan di compose terpisah di VM yang sama
# DAN kamu menggunakan docker-compose.network.yml override.
# Cari nama network-nya: docker network ls | grep kafka
# KAFKA_DOCKER_NETWORK=kafka-boilerplate_default
